#!/usr/bin/with-contenv bashio
set -e

HA_SQLITE="/config/home-assistant_v2.db"
DB_COPY="/data/ha_recorder.db"
INTERVAL=300  # 5 minutes

if [ ! -f "$HA_SQLITE" ]; then
    bashio::log.info "db-sync: no SQLite DB at ${HA_SQLITE}, sleeping."
    exec sleep infinity
fi

bashio::log.info "db-sync: refreshing ${DB_COPY} from ${HA_SQLITE} every ${INTERVAL}s."

while true; do
    sleep "$INTERVAL"
    # VACUUM INTO only needs read access; no lock files on the ro mount.
    # Remove stale copy first so VACUUM INTO does not fail on existing file.
    rm -f "$DB_COPY"
    sqlite3 "file:${HA_SQLITE}?mode=ro&immutable=1" "VACUUM INTO '${DB_COPY}';"
    bashio::log.debug "db-sync: snapshot refreshed."
done
