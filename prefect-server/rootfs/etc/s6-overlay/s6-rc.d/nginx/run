#!/command/with-contenv bashio
# ==============================================================================
# Configure and start nginx – ingress + optional external access
# ==============================================================================

INTERNAL_PORT=4201          # Prefect server internal port
INGRESS_PORT=8099           # HA ingress port
EXTERNAL_PORT=4200          # External access port (exposed to network)

# Clean up previous configs
rm -f /etc/nginx/sites-enabled/* /etc/nginx/conf.d/*.conf

AUTH_TYPE=$(bashio::config 'auth_type')
NETWORK_ACCESS=$(bashio::config 'network_access')

# Wait for Prefect to be ready
bashio::log.info "Waiting for Prefect Server to become available..."
for i in $(seq 1 60); do
    if curl -sf "http://127.0.0.1:${INTERNAL_PORT}/api/health" > /dev/null 2>&1; then
        bashio::log.info "Prefect Server is ready."
        break
    fi
    if [ "$i" -eq 60 ]; then
        bashio::log.warning "Prefect Server did not respond within 60 seconds, starting nginx anyway..."
    fi
    sleep 1
done

# ---------------------------------------------------------------------------
# WebSocket upgrade map (required for all server blocks)
# ---------------------------------------------------------------------------
cat > /etc/nginx/conf.d/00-maps.conf <<'NGINX'
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}
NGINX

# ---------------------------------------------------------------------------
# Ingress server – only accessible from HA supervisor (172.30.32.2)
#
# Prefect UI is a Vite SPA that uses absolute paths (/assets/..., /api/...).
# Through HA ingress the browser sits at /api/hassio_ingress/<token>/ and
# absolute paths bypass the ingress proxy entirely.
#
# Fix: sub_filter rewrites absolute paths to relative (./) so the browser
# resolves them against the ingress base URL:
#   /assets/main.js  →  ./assets/main.js
#   → browser resolves to /api/hassio_ingress/<token>/assets/main.js
#   → HA supervisor strips prefix → nginx gets GET /assets/main.js  ✓
#
# IMPORTANT: proxy_set_header Accept-Encoding "" disables gzip from upstream
# because sub_filter cannot process compressed content.
# ---------------------------------------------------------------------------
bashio::log.info "Configuring ingress on port ${INGRESS_PORT}..."

cat > /etc/nginx/conf.d/ingress.conf <<NGINX
server {
    listen ${INGRESS_PORT};
    allow 172.30.32.2;
    deny  all;

    # Serve the ingress routing shim (patched into <head> via sub_filter)
    location = /ingress-shim.js {
        root /usr/share/nginx/html;
    }

    # Serve UI pages and static assets – with path rewriting
    location / {
        proxy_pass         http://127.0.0.1:${INTERNAL_PORT}/;
        proxy_http_version 1.1;
        proxy_set_header   Host              \$http_host;
        proxy_set_header   Upgrade           \$http_upgrade;
        proxy_set_header   Connection        \$connection_upgrade;
        proxy_set_header   X-Real-IP         \$remote_addr;
        proxy_set_header   X-Forwarded-For   \$proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto \$scheme;
        proxy_buffering    off;

        # Prefect UI uses Server-Sent Events for real-time updates
        proxy_read_timeout    86400s;
        proxy_send_timeout    86400s;
        proxy_connect_timeout 60s;

        # --- Ingress SPA path rewriting ---
        # Disable upstream compression so sub_filter can inspect the body
        proxy_set_header   Accept-Encoding "";

        sub_filter_once off;
        sub_filter_types application/javascript text/javascript text/css;

        # Inject ingress routing shim BEFORE app scripts load.
        # The shim patches history.pushState/replaceState and Vue Router
        # so the SPA works correctly behind the HA ingress path.
        sub_filter '</head>' '<script src="./ingress-shim.js"></script></head>';

        # HTML attributes: <script src="/..."> , <link href="/...">
        sub_filter 'src="/'    'src="./';
        sub_filter "src='/"    "src='./";
        sub_filter 'href="/'   'href="./';
        sub_filter "href='/"   "href='./";
        # JS string literals: fetch("/api/..."), const url = "/api"
        sub_filter '"/api'     '"./api';
        sub_filter "'/api"     "'./api";
        # JS template literals: \`/api/...\`
        sub_filter '\`/api'    '\`./api';
        # CSS url() references: url(/static/...)
        sub_filter 'url(/'     'url(./';
    }

    # Prefect API endpoint – no sub_filter (JSON must pass through unchanged)
    location /api/ {
        proxy_pass         http://127.0.0.1:${INTERNAL_PORT}/api/;
        proxy_http_version 1.1;
        proxy_set_header   Host              \$http_host;
        proxy_set_header   X-Real-IP         \$remote_addr;
        proxy_set_header   X-Forwarded-For   \$proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto \$scheme;
        proxy_buffering    off;
        proxy_read_timeout 86400s;
    }
}
NGINX

# ---------------------------------------------------------------------------
# External server – optional, with authentication
# ---------------------------------------------------------------------------
if [ "${NETWORK_ACCESS}" = "true" ]; then
    bashio::log.info "External access enabled on port ${EXTERNAL_PORT}."

    case "${AUTH_TYPE}" in
        basic)
            USERNAME=$(bashio::config 'username')
            PASSWORD=$(bashio::config 'password')

            if [ -z "$USERNAME" ] || [ -z "$PASSWORD" ]; then
                bashio::log.fatal \
                    "auth_type=basic requires username and password to be set."
                bashio::exit.nok
            fi

            htpasswd -cb /etc/nginx/.htpasswd "$USERNAME" "$PASSWORD"
            bashio::log.info "External access: Basic Auth (user: ${USERNAME})"

            cat > /etc/nginx/conf.d/external.conf <<NGINX
server {
    listen ${EXTERNAL_PORT};

    auth_basic           "Prefect Server";
    auth_basic_user_file /etc/nginx/.htpasswd;

    location / {
        proxy_pass         http://127.0.0.1:${INTERNAL_PORT}/;
        proxy_http_version 1.1;
        proxy_set_header   Host              \$http_host;
        proxy_set_header   Upgrade           \$http_upgrade;
        proxy_set_header   Connection        \$connection_upgrade;
        proxy_set_header   X-Real-IP         \$remote_addr;
        proxy_set_header   X-Forwarded-For   \$proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto \$scheme;
        proxy_buffering    off;
        proxy_read_timeout 86400s;
    }
}
NGINX
            ;;
        bearer)
            BEARER_TOKEN=$(bashio::config 'bearer_token')

            if [ -z "$BEARER_TOKEN" ]; then
                bashio::log.fatal \
                    "auth_type=bearer requires bearer_token to be set."
                bashio::exit.nok
            fi

            bashio::log.info "External access: Bearer Token"

            cat > /etc/nginx/conf.d/external-bearer-map.conf <<NGINX
map \$http_authorization \$bearer_valid {
    default                    0;
    "Bearer ${BEARER_TOKEN}"   1;
}
NGINX

            cat > /etc/nginx/conf.d/external.conf <<NGINX
server {
    listen ${EXTERNAL_PORT};

    if (\$bearer_valid = 0) {
        return 401;
    }

    add_header WWW-Authenticate 'Bearer realm="Prefect Server"' always;

    location / {
        proxy_pass         http://127.0.0.1:${INTERNAL_PORT}/;
        proxy_http_version 1.1;
        proxy_set_header   Host              \$http_host;
        proxy_set_header   Upgrade           \$http_upgrade;
        proxy_set_header   Connection        \$connection_upgrade;
        proxy_set_header   X-Real-IP         \$remote_addr;
        proxy_set_header   X-Forwarded-For   \$proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto \$scheme;
        proxy_buffering    off;
        proxy_read_timeout 86400s;
    }
}
NGINX
            ;;
        *)
            bashio::log.warning "============================================="
            bashio::log.warning " EXTERNAL ACCESS WITHOUT AUTHENTICATION!"
            bashio::log.warning " Set auth_type to 'basic' or 'bearer'."
            bashio::log.warning "============================================="

            cat > /etc/nginx/conf.d/external.conf <<NGINX
server {
    listen ${EXTERNAL_PORT};

    location / {
        proxy_pass         http://127.0.0.1:${INTERNAL_PORT}/;
        proxy_http_version 1.1;
        proxy_set_header   Host              \$http_host;
        proxy_set_header   Upgrade           \$http_upgrade;
        proxy_set_header   Connection        \$connection_upgrade;
        proxy_set_header   X-Real-IP         \$remote_addr;
        proxy_set_header   X-Forwarded-For   \$proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto \$scheme;
        proxy_buffering    off;
        proxy_read_timeout 86400s;
    }
}
NGINX
            ;;
    esac
else
    bashio::log.info "External access disabled."
fi

# ---------------------------------------------------------------------------
# Start nginx
# ---------------------------------------------------------------------------
bashio::log.info "Starting nginx..."
exec nginx -g 'daemon off;'
