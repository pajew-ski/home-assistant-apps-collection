#!/command/with-contenv bashio
# ==============================================================================
# Configure and start nginx – ingress + optional external access
# ==============================================================================

# Clean up previous configs
rm -f /etc/nginx/sites-enabled/* /etc/nginx/conf.d/*.conf

AUTH_TYPE=$(bashio::config 'auth_type')
NETWORK_ACCESS=$(bashio::config 'network_access')

# Wait for Prefect to be ready
bashio::log.info "Waiting for Prefect Server to become available..."
for i in $(seq 1 60); do
    if curl -sf http://127.0.0.1:4200/api/health > /dev/null 2>&1; then
        bashio::log.info "Prefect Server is ready."
        break
    fi
    if [ "$i" -eq 60 ]; then
        bashio::log.warning "Prefect Server did not respond within 60 seconds, starting nginx anyway..."
    fi
    sleep 1
done

# ---------------------------------------------------------------------------
# Ingress server – only accessible from HA supervisor (172.30.32.2)
# ---------------------------------------------------------------------------
bashio::log.info "Configuring ingress on port 8099..."

cat > /etc/nginx/conf.d/ingress.conf <<'NGINX'
server {
    listen 8099;
    allow 172.30.32.2;
    deny  all;

    location / {
        proxy_pass         http://127.0.0.1:4200/;
        proxy_http_version 1.1;
        proxy_set_header   Host              $http_host;
        proxy_set_header   Upgrade           $http_upgrade;
        proxy_set_header   Connection        $connection_upgrade;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_buffering    off;

        # Prefect UI uses Server-Sent Events for real-time updates
        proxy_read_timeout    86400s;
        proxy_send_timeout    86400s;
        proxy_connect_timeout 60s;

        # Sub-filter to rewrite API base URL for ingress path
        sub_filter_once off;
        sub_filter_types application/javascript text/html;
    }

    # Prefect API endpoint
    location /api/ {
        proxy_pass         http://127.0.0.1:4200/api/;
        proxy_http_version 1.1;
        proxy_set_header   Host              $http_host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_buffering    off;
        proxy_read_timeout 86400s;
    }
}
NGINX

# ---------------------------------------------------------------------------
# WebSocket upgrade map (required for all server blocks)
# ---------------------------------------------------------------------------
cat > /etc/nginx/conf.d/00-maps.conf <<'NGINX'
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}
NGINX

# ---------------------------------------------------------------------------
# External server – optional, with authentication
# ---------------------------------------------------------------------------
if [ "${NETWORK_ACCESS}" = "true" ]; then
    bashio::log.info "External access enabled on port 4200."

    case "${AUTH_TYPE}" in
        basic)
            USERNAME=$(bashio::config 'username')
            PASSWORD=$(bashio::config 'password')

            if [ -z "$USERNAME" ] || [ -z "$PASSWORD" ]; then
                bashio::log.fatal \
                    "auth_type=basic requires username and password to be set."
                bashio::exit.nok
            fi

            htpasswd -cb /etc/nginx/.htpasswd "$USERNAME" "$PASSWORD"
            bashio::log.info "External access: Basic Auth (user: ${USERNAME})"

            cat > /etc/nginx/conf.d/external.conf <<NGINX
server {
    listen 4200;

    auth_basic           "Prefect Server";
    auth_basic_user_file /etc/nginx/.htpasswd;

    location / {
        proxy_pass         http://127.0.0.1:4200/;
        proxy_http_version 1.1;
        proxy_set_header   Host              \$http_host;
        proxy_set_header   Upgrade           \$http_upgrade;
        proxy_set_header   Connection        \$connection_upgrade;
        proxy_set_header   X-Real-IP         \$remote_addr;
        proxy_set_header   X-Forwarded-For   \$proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto \$scheme;
        proxy_buffering    off;
        proxy_read_timeout 86400s;
    }
}
NGINX
            ;;
        bearer)
            BEARER_TOKEN=$(bashio::config 'bearer_token')

            if [ -z "$BEARER_TOKEN" ]; then
                bashio::log.fatal \
                    "auth_type=bearer requires bearer_token to be set."
                bashio::exit.nok
            fi

            bashio::log.info "External access: Bearer Token"

            cat > /etc/nginx/conf.d/external-bearer-map.conf <<NGINX
map \$http_authorization \$bearer_valid {
    default                    0;
    "Bearer ${BEARER_TOKEN}"   1;
}
NGINX

            cat > /etc/nginx/conf.d/external.conf <<'NGINX'
server {
    listen 4200;

    if ($bearer_valid = 0) {
        return 401;
    }

    add_header WWW-Authenticate 'Bearer realm="Prefect Server"' always;

    location / {
        proxy_pass         http://127.0.0.1:4200/;
        proxy_http_version 1.1;
        proxy_set_header   Host              $http_host;
        proxy_set_header   Upgrade           $http_upgrade;
        proxy_set_header   Connection        $connection_upgrade;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_buffering    off;
        proxy_read_timeout 86400s;
    }
}
NGINX
            ;;
        *)
            bashio::log.warning "============================================="
            bashio::log.warning " EXTERNAL ACCESS WITHOUT AUTHENTICATION!"
            bashio::log.warning " Set auth_type to 'basic' or 'bearer'."
            bashio::log.warning "============================================="

            cat > /etc/nginx/conf.d/external.conf <<'NGINX'
server {
    listen 4200;

    location / {
        proxy_pass         http://127.0.0.1:4200/;
        proxy_http_version 1.1;
        proxy_set_header   Host              $http_host;
        proxy_set_header   Upgrade           $http_upgrade;
        proxy_set_header   Connection        $connection_upgrade;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_buffering    off;
        proxy_read_timeout 86400s;
    }
}
NGINX
            ;;
    esac
else
    bashio::log.info "External access disabled."
fi

# ---------------------------------------------------------------------------
# Start nginx
# ---------------------------------------------------------------------------
bashio::log.info "Starting nginx..."
exec nginx -g 'daemon off;'
