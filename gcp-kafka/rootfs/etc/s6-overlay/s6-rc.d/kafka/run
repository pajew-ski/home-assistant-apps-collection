#!/command/with-contenv bashio
# ==============================================================================
# Start Apache Kafka in KRaft mode (no ZooKeeper required)
# ==============================================================================

KAFKA_DATA="/data/kafka"
KAFKA_LOGS="${KAFKA_DATA}/logs"
KAFKA_PORT=9092

mkdir -p "${KAFKA_DATA}" "${KAFKA_LOGS}"

KAFKA_EXTERNAL=$(bashio::config 'kafka_external')

# Generate KRaft cluster ID if not present
if [ ! -f "${KAFKA_DATA}/cluster-id" ]; then
    CLUSTER_ID=$(/opt/kafka/bin/kafka-storage.sh random-uuid)
    echo "${CLUSTER_ID}" > "${KAFKA_DATA}/cluster-id"
    bashio::log.info "Generated Kafka cluster ID: ${CLUSTER_ID}"
fi

CLUSTER_ID=$(cat "${KAFKA_DATA}/cluster-id")

# Build listeners based on external access setting
LISTENERS="PLAINTEXT://127.0.0.1:${KAFKA_PORT},CONTROLLER://127.0.0.1:9093"
ADVERTISED="PLAINTEXT://127.0.0.1:${KAFKA_PORT}"

if [ "${KAFKA_EXTERNAL}" = "true" ]; then
    LISTENERS="PLAINTEXT://0.0.0.0:${KAFKA_PORT},CONTROLLER://127.0.0.1:9093"
    ADVERTISED="PLAINTEXT://0.0.0.0:${KAFKA_PORT}"
    bashio::log.warning "Kafka broker exposed externally on port ${KAFKA_PORT}."
fi

# Generate KRaft server properties
cat > /opt/kafka/config/kraft-server.properties <<EOF
# KRaft mode configuration
process.roles=broker,controller
node.id=1
controller.quorum.voters=1@127.0.0.1:9093
controller.listener.names=CONTROLLER

listeners=${LISTENERS}
advertised.listeners=${ADVERTISED}
listener.security.protocol.map=CONTROLLER:PLAINTEXT,PLAINTEXT:PLAINTEXT
inter.broker.listener.name=PLAINTEXT

log.dirs=${KAFKA_LOGS}
num.partitions=4
default.replication.factor=1
offsets.topic.replication.factor=1
transaction.state.log.replication.factor=1
transaction.state.log.min.isr=1
log.retention.hours=168
log.segment.bytes=1073741824
EOF

# Format storage if not yet formatted
if [ ! -f "${KAFKA_LOGS}/meta.properties" ]; then
    bashio::log.info "Formatting Kafka storage..."
    /opt/kafka/bin/kafka-storage.sh format \
        -t "${CLUSTER_ID}" \
        -c /opt/kafka/config/kraft-server.properties
fi

bashio::log.info "Starting Kafka broker (KRaft mode)..."
exec /opt/kafka/bin/kafka-server-start.sh /opt/kafka/config/kraft-server.properties
