#!/command/with-contenv bashio
# ==============================================================================
# Configure and start nginx – ingress + optional external access
# ==============================================================================

INTERNAL_PORT=8080          # NetOps API internal port
INGRESS_PORT=8099           # HA ingress port
EXTERNAL_PORT=9080          # External access port

rm -f /etc/nginx/sites-enabled/* /etc/nginx/conf.d/*.conf

AUTH_TYPE=$(bashio::config 'auth_type')
NETWORK_ACCESS=$(bashio::config 'network_access')

# Wait for NetOps API
bashio::log.info "Waiting for NetOps API..."
for i in $(seq 1 30); do
    if curl -sf "http://127.0.0.1:${INTERNAL_PORT}/api/status" > /dev/null 2>&1; then
        bashio::log.info "NetOps API is ready."
        break
    fi
    [ "$i" -eq 30 ] && bashio::log.warning "NetOps API not ready after 30s, starting nginx anyway..."
    sleep 1
done

# ---------------------------------------------------------------------------
# WebSocket upgrade map
# ---------------------------------------------------------------------------
cat > /etc/nginx/conf.d/00-maps.conf <<'NGINX'
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}
NGINX

# ---------------------------------------------------------------------------
# Ingress server – HA supervisor only
# ---------------------------------------------------------------------------
bashio::log.info "Configuring ingress on port ${INGRESS_PORT}..."

cat > /etc/nginx/conf.d/ingress.conf <<NGINX
server {
    listen ${INGRESS_PORT};
    allow 172.30.32.2;
    deny  all;

    client_max_body_size 50m;

    location / {
        proxy_pass         http://127.0.0.1:${INTERNAL_PORT}/;
        proxy_http_version 1.1;
        proxy_set_header   Host              \$http_host;
        proxy_set_header   Upgrade           \$http_upgrade;
        proxy_set_header   Connection        \$connection_upgrade;
        proxy_set_header   X-Real-IP         \$remote_addr;
        proxy_set_header   X-Forwarded-For   \$proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto \$scheme;
        proxy_buffering    off;
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;
    }
}
NGINX

# ---------------------------------------------------------------------------
# External server – optional, with authentication
# ---------------------------------------------------------------------------
if [ "${NETWORK_ACCESS}" = "true" ]; then
    bashio::log.info "External access enabled on port ${EXTERNAL_PORT}."

    case "${AUTH_TYPE}" in
        basic)
            USERNAME=$(bashio::config 'username')
            PASSWORD=$(bashio::config 'password')

            if [ -z "$USERNAME" ] || [ -z "$PASSWORD" ]; then
                bashio::log.fatal \
                    "auth_type=basic requires username and password to be set."
                bashio::exit.nok
            fi

            htpasswd -cb /etc/nginx/.htpasswd "$USERNAME" "$PASSWORD"
            bashio::log.info "External access: Basic Auth (user: ${USERNAME})"

            cat > /etc/nginx/conf.d/external.conf <<NGINX
server {
    listen ${EXTERNAL_PORT};

    auth_basic           "NetOps Platform";
    auth_basic_user_file /etc/nginx/.htpasswd;

    client_max_body_size 50m;

    location / {
        proxy_pass         http://127.0.0.1:${INTERNAL_PORT}/;
        proxy_http_version 1.1;
        proxy_set_header   Host              \$http_host;
        proxy_set_header   Upgrade           \$http_upgrade;
        proxy_set_header   Connection        \$connection_upgrade;
        proxy_set_header   X-Real-IP         \$remote_addr;
        proxy_set_header   X-Forwarded-For   \$proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto \$scheme;
        proxy_buffering    off;
        proxy_read_timeout 86400s;
    }
}
NGINX
            ;;
        bearer)
            BEARER_TOKEN=$(bashio::config 'bearer_token')

            if [ -z "$BEARER_TOKEN" ]; then
                bashio::log.fatal \
                    "auth_type=bearer requires bearer_token to be set."
                bashio::exit.nok
            fi

            bashio::log.info "External access: Bearer Token"

            cat > /etc/nginx/conf.d/external-bearer-map.conf <<NGINX
map \$http_authorization \$bearer_valid {
    default                    0;
    "Bearer ${BEARER_TOKEN}"   1;
}
NGINX

            cat > /etc/nginx/conf.d/external.conf <<NGINX
server {
    listen ${EXTERNAL_PORT};

    if (\$bearer_valid = 0) {
        return 401;
    }

    add_header WWW-Authenticate 'Bearer realm="NetOps Platform"' always;

    client_max_body_size 50m;

    location / {
        proxy_pass         http://127.0.0.1:${INTERNAL_PORT}/;
        proxy_http_version 1.1;
        proxy_set_header   Host              \$http_host;
        proxy_set_header   Upgrade           \$http_upgrade;
        proxy_set_header   Connection        \$connection_upgrade;
        proxy_set_header   X-Real-IP         \$remote_addr;
        proxy_set_header   X-Forwarded-For   \$proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto \$scheme;
        proxy_buffering    off;
        proxy_read_timeout 86400s;
    }
}
NGINX
            ;;
        *)
            bashio::log.warning "============================================="
            bashio::log.warning " EXTERNAL ACCESS WITHOUT AUTHENTICATION!"
            bashio::log.warning " Set auth_type to 'basic' or 'bearer'."
            bashio::log.warning "============================================="

            cat > /etc/nginx/conf.d/external.conf <<NGINX
server {
    listen ${EXTERNAL_PORT};

    client_max_body_size 50m;

    location / {
        proxy_pass         http://127.0.0.1:${INTERNAL_PORT}/;
        proxy_http_version 1.1;
        proxy_set_header   Host              \$http_host;
        proxy_set_header   Upgrade           \$http_upgrade;
        proxy_set_header   Connection        \$connection_upgrade;
        proxy_set_header   X-Real-IP         \$remote_addr;
        proxy_set_header   X-Forwarded-For   \$proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto \$scheme;
        proxy_buffering    off;
        proxy_read_timeout 86400s;
    }
}
NGINX
            ;;
    esac
else
    bashio::log.info "External access disabled."
fi

bashio::log.info "Starting nginx..."
exec nginx -g 'daemon off;'
